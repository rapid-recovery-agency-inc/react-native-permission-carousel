{
  "name": "@rapid-recovery-agency-inc/react-native-permission-carousel",
  "version": "0.0.1",
  "description": "React native permission carousel to manage user prompt, request and permission warnings across Insightt mobile projects",
  "type": "module",
  "publishConfig": {
    "@rapid-recovery-agency-inc:registry": "https://npm.pkg.github.com"
  },
  "main": "src/index.ts",
  "keywords": [
    "react-native",
    "permissions"
  ],
  "author": "Jonathan Miles (jonathandanielmiles@gmail.com)",
  "license": "ISC",
  "scripts": {
    "precommit": "npm run lint && npm run format-check && npm run typecheck && npm run test && npm run build",
    "build": "tsc --project ./tsconfig.json",
    "format": "prettier --write ./src",
    "format-check": "prettier --check ./src",
    "lint": "eslint src",
    "lint-fix": "eslint --fix src",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "test": "jest --config=./jest.config.cjs",
    "test-watch": "npm run test -- --watch",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "dependencies": {
    "@rapid-recovery-agency-inc/sloth-ui-mobile": "^1.268.0",
    "@types/luxon": "^3.7.1",
    "@types/react-native-vector-icons": "^6.4.18",
    "lint-staged": "^16.4.0",
    "lodash": "^4.18.1",
    "react": ">=18.2.0 <20.0.0",
    "react-native": ">=0.71.16 <=0.81.4",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-permissions": "^5.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-flow-strip-types": "^7.24.0",
    "@babel/plugin-transform-typescript": "^7.24.0",
    "@eslint/js": "^9.0.0",
    "@jest/globals": "^30.0.0",
    "@rapid-recovery-agency-inc/eslint-plugin-rra": "^0.22.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native/babel-preset": "^0.85.1",
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^30.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "globals": "^16.0.0",
    "husky": "^9.0.0",
    "i18next": "^26.0.4",
    "jest": "^30.0.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.0.0",
    "react-dom": "^19.2.5",
    "react-test-renderer": "^19.2.5",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "i18next": ">=23.0.0",
    "react": ">=18.2.0 <20.0.0",
    "react-native": ">=0.71.16 <=0.81.4",
    "react-native-permissions": "^5.5.1"
  }
}
